# sdist 排除 Node 二进制（平台相关大文件，由各平台 wheel 单独携带）
exclude midscene_android/_node_driver/bin/node-*
exclude midscene_android/_node_driver/npm/

# 包含必要的源码文件
include midscene_android/_node_driver/src/*.js
include midscene_android/_node_driver/src/*.json
include README.md
include LICENSE
include pyproject.toml